# Copy to evaluate/.env and fill in.
# 同步驱动；asyncpg 不支持 pandas.read_sql。
# 例：postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# 可选：SSL 是否严格校验证书链 (true/false)
DATABASE_SSL_VERIFY=false

# 输出目录（CSV / JSON 报告产物）
OUTPUT_DIR=evaluate/output

# alpha 显著性阈值
ALPHA=0.05
